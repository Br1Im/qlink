# Development Frontend Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
COPY packages/frontend/package*.json ./packages/frontend/
RUN npm install --legacy-peer-deps

# Install SWC binary for alpine
RUN cd packages/frontend && npm install @next/swc-linux-x64-musl --save-optional || true

# Copy source code
COPY tsconfig.json ./
COPY packages/frontend ./packages/frontend

WORKDIR /app/packages/frontend

EXPOSE 3000

# Run with hot reload
CMD ["npm", "run", "dev"]
